. 
. *--------------------------------------------------------------------------
. * INPUT CHECK
. *--------------------------------------------------------------------------
. 
. capture confirm file "tables/table8_annual_bilateral_trade.csv"

. if _rc != 0 {
.     di as error "Missing required input: tables/table8_annual_bilateral_trade.csv"
.     log close
.     exit 601
. }

