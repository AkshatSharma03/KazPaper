. * IMPROVEMENT: Define HAC SE program
. capture program drop run_hac_regression

. program define run_hac_regression
  1.     syntax varlist(min=2) [if] [in], Name(string) [Lags(integer 1)]
  2.     
.     quietly regress `varlist' `if' `in'
  3.     estimates store `name'_ols
  4.     
.     * Newey-West HAC SEs
.     quietly newey `varlist' `if' `in', lag(`lags')
  5.     estimates store `name'_hac
  6.     
.     * Robust SEs for comparison
.     quietly regress `varlist' `if' `in', vce(robust)
  7.     estimates store `name'_rob
  8.     
.     di _newline "Model: `name'"
  9.     di "  OLS (conventional SEs):"
 10.     estimates table `name'_ols, b(%9.4f) se(%9.4f) stats(N r2)
 11.     
.     di _newline "  Newey-West HAC SEs (lag=`lags'):"
 12.     estimates table `name'_hac, b(%9.4f) se(%9.4f) stats(N r2)
 13.     
.     di _newline "  Robust SEs (for comparison):"
 14.     estimates table `name'_rob, b(%9.4f) se(%9.4f) stats(N r2)
 15. end

. 
