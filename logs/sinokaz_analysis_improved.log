. di _newline "--- Manual break-point search (interior years 2017-2021) ---"

--- Manual break-point search (interior years 2017-2021) ---

. di "  Year | Chow F | p-value"
  Year | Chow F | p-value

. di "  -----|--------|--------"
  -----|--------|--------

. 
. scalar best_f    = .

. scalar best_p    = .

. scalar best_year = .

. 
. forvalues bp = 2017/2021 {
  2.     quietly regress trade_balance t
  3.     scalar rss_r_loop = e(rss)
  4.     
.     gen d_bp = (year >= `bp')
  5.     gen t_bp = t * d_bp
  6.     
.     quietly regress trade_balance t d_bp t_bp
  7.     scalar rss_u_loop = e(rss)
  8.     scalar df_u_loop  = e(df_r)
  9.     scalar f_loop     = ((rss_r_loop - rss_u_loop) / q) / (rss_u_loop / df_u_loop)
 10.     scalar p_loop     = Ftail(q, df_u_loop, f_loop)
 11.     
.     di "  `bp'  | " %6.4f f_loop " | " %6.4f p_loop
 12.     
.     if missing(best_f) | f_loop > best_f {
 13.         scalar best_f    = f_loop
 14.         scalar best_p    = p_loop
 15.         scalar best_year = `bp'
 16.     }
 17.     
.     drop d_bp t_bp
 18. }
  2017  | 0.1816 | 0.8384
  2018  | 0.3539 | 0.7157
  2019  | 0.9836 | 0.4271
  2020  | 3.8858 | 0.0827
  2021  | 3.4866 | 0.0989

. 
. di _newline "Most likely structural break year: " best_year

Most likely structural break year: 2020

. di "Highest Chow F: " %6.4f best_f
Highest Chow F: 3.8858

. di "Associated p-value: " %6.4f best_p
