. di _newline(2) "======= CHOW STRUCTURAL BREAK TEST (IMPROVED) ======="


======= CHOW STRUCTURAL BREAK TEST (IMPROVED) =======

. 
. di _newline "--- Chow Test: Break at 2020 ---"

--- Chow Test: Break at 2020 ---

. 
. * IMPROVEMENT: Use HAC (Newey-West) standard errors
. quietly regress trade_balance t

. scalar rss_r = e(rss)

. 
. gen d2020   = (year >= 2020)

. gen t_d2020 = t * d2020

. 
. quietly regress trade_balance t d2020 t_d2020

. scalar rss_u = e(rss)

. scalar df_u  = e(df_r)

. scalar q     = 2

. 
. scalar chow_f = ((rss_r - rss_u) / q) / (rss_u / df_u)

. scalar chow_p = Ftail(q, df_u, chow_f)

. 
. di "Chow F-statistic (break at 2020): " %8.4f chow_f
Chow F-statistic (break at 2020):   3.8858

. di "p-value: " %8.4f chow_p
p-value:   0.0827

. 
. di _newline "--- Wald test: joint significance of break terms (HAC SEs) ---"

--- Wald test: joint significance of break terms (HAC SEs) ---

. test d2020 t_d2020

