. * Claim 3: Structural Break
. quietly regress trade_balance t

. local rss_r = e(rss)

. 
. gen d2020 = (year >= 2020)

. gen t_d2020 = t * d2020

. quietly regress trade_balance t d2020 t_d2020

. local rss_u = e(rss)

. local df_u = e(df_r)

. local q = 2

. local chow_f = ((`rss_r' - `rss_u') / `q') / (`rss_u' / `df_u')

. local chow_p = Ftail(`q', `df_u', `chow_f')

. drop d2020 t_d2020

