. * Helper to assign significance stars
. program define assign_stars
  1.     args pval rownum
  2.     if `pval' < 0.001 {
  3.         replace significance = "***" in `rownum'
  4.     }
  5.     else if `pval' < 0.01 {
  6.         replace significance = "**" in `rownum'
  7.     }
  8.     else if `pval' < 0.05 {
  9.         replace significance = "*" in `rownum'
 10.     }
 11.     else if `pval' < 0.10 {
 12.         replace significance = "†" in `rownum'
 13.     }
 14.     else {
 15.         replace significance = "" in `rownum'
 16.     }
 17. end

