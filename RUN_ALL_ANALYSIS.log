. * ADF test for exports
. di _newline "exports (exports_bn):"

exports (exports_bn):

. quietly dfuller exports_bn, lags(1) trend

. scalar exports_adf_stat = r(Z_t)

. scalar exports_adf_p5 = r(ct_5)

. scalar exports_adf_p1 = r(ct_1)

. scalar exports_adf_N = e(N)

. di "  ADF statistic: " %8.4f exports_adf_stat
