. 
. di _newline(2) "=== CLAIM 3: STRUCTURAL BREAK (CHOW TEST) ==="


=== CLAIM 3: STRUCTURAL BREAK (CHOW TEST) ===

. 
. quietly regress trade_balance t

. scalar rss_r = e(rss)

. 
. gen d2020 = (year >= 2020)

. gen t_d2020 = t * d2020

. quietly regress trade_balance t d2020 t_d2020

. scalar rss_u = e(rss)

. scalar df_u = e(df_r)

. scalar q = 2

. scalar c3_chow_f = ((rss_r - rss_u) / q) / (rss_u / df_u)

. scalar c3_chow_p = Ftail(q, df_u, c3_chow_f)

. scalar c3_break = _b[d2020]

. scalar c3_break_se = _se[d2020]

. 
. drop d2020 t_d2020

. 
. di "Chow F: " %6.4f c3_chow_f " (p=" %6.4f c3_chow_p ")"
Chow F: 3.8858 (p=0.0827)

. di "Break shift: " %6.3f c3_break " (SE=" %6.3f c3_break_se ")"
Break shift: 28.105 (SE=10.377)

