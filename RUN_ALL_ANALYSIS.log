. di "  Observations: " exports_adf_N
  Observations: .

. if exports_adf_stat < exports_adf_p5 {
.     di "  RESULT: REJECT unit root at 5% - variable is STATIONARY"
.     scalar exports_stationary = 1
. }

. else {
.     di "  RESULT: FAIL to reject unit root at 5% - may be NON-STATIONARY"
